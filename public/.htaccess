Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    RewriteRule ^article/([0-9]+)/?$ view_article.php?id_article=$1 [L,QSA]
    RewriteRule ^category/([0-9]+)/?$ category.php?id_category=$1 [L,QSA]
    RewriteRule ^user/([0-9]+)/?$ user.php?id_user=$1 [L,QSA]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

ErrorDocument 404 /error.php
ErrorDocument 500 /error.php

<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "no-referrer-when-downgrade"
</IfModule>

<FilesMatch "\.(env|yml|yaml|ini|log|sql|sh|inc|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<Files ".htaccess">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</Files>

RedirectMatch 403 ^/configs/.*$
RedirectMatch 403 ^/src/.*$
RedirectMatch 403 ^/\.git/.*$
